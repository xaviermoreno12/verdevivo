---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITIO, MARCA, urlAbsoluta } from '../lib/sitio.ts';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  tipo?: 'website' | 'article';
  schema?: Record<string, any> | Record<string, any>[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath = '/',
  ogImage,
  tipo = 'website',
  schema,
  noindex = false,
} = Astro.props;

const canonical = urlAbsoluta(canonicalPath);
const titleFull = canonicalPath === '/' ? title : `${title} | ${SITIO.nombre}`;
const fuentesTitulos = (MARCA.fuente_titulos || 'Bricolage Grotesque').replace(/ /g, '+');
const fuentesTexto = (MARCA.fuente_texto || 'Inter').replace(/ /g, '+');
const ga = SITIO.ga_id;
---
<!doctype html>
<html lang={SITIO.idioma || 'es'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titleFull}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {SITIO.gsc_verification && (
      <meta name="google-site-verification" content={SITIO.gsc_verification} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={tipo} />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITIO.nombre} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={titleFull} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href={`https://fonts.googleapis.com/css2?family=${fuentesTitulos}:wght@600;700;800&family=${fuentesTexto}:wght@400;600;700&display=swap`}
    />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Colores de marca (por sitio) -->
    <style define:vars={{
      primario: MARCA.color_primario,
      secundario: MARCA.color_secundario,
      acento: MARCA.color_acento,
      fondo: MARCA.fondo || '#ffffff',
      'fuente-titulos': `'${MARCA.fuente_titulos}'`,
      'fuente-texto': `'${MARCA.fuente_texto}'`,
    }}></style>

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Google Analytics 4 -->
    {ga && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga}`}></script>
        <script is:inline define:vars={{ ga }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ga);
        </script>
      </>
    )}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
