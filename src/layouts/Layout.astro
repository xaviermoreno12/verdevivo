---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITIO, MARCA, urlAbsoluta } from '../lib/sitio.ts';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  tipo?: 'website' | 'article';
  schema?: Record<string, any> | Record<string, any>[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath = '/',
  ogImage,
  tipo = 'website',
  schema,
  noindex = false,
} = Astro.props;

const canonical = urlAbsoluta(canonicalPath);
const titleFull = canonicalPath === '/' ? title : `${title} | ${SITIO.nombre}`;
const fuentesTitulos = (MARCA.fuente_titulos || 'Bricolage Grotesque').replace(/ /g, '+');
const fuentesTexto = (MARCA.fuente_texto || 'Inter').replace(/ /g, '+');
const ga = SITIO.ga_id;
---
<!doctype html>
<html lang={SITIO.idioma || 'es'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{titleFull}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {SITIO.gsc_verification && (
      <meta name="google-site-verification" content={SITIO.gsc_verification} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={tipo} />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITIO.nombre} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={titleFull} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href={`https://fonts.googleapis.com/css2?family=${fuentesTitulos}:wght@600;700;800&family=${fuentesTexto}:wght@400;600;700&display=swap`}
    />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Colores de marca (por sitio) -->
    <style define:vars={{
      primario: MARCA.color_primario,
      secundario: MARCA.color_secundario,
      acento: MARCA.color_acento,
      fondo: MARCA.fondo || '#ffffff',
      'fuente-titulos': `'${MARCA.fuente_titulos}'`,
      'fuente-texto': `'${MARCA.fuente_texto}'`,
    }}></style>

    <!-- Organización (marca) — ayuda a que Google y las IA reconozcan la entidad -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: SITIO.nombre,
      url: urlAbsoluta('/'),
      description: SITIO.descripcion,
      slogan: SITIO.tagline,
    })} />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Google Analytics 4 -->
    {ga && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga}`}></script>
        <script is:inline define:vars={{ ga }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ga);
        </script>
      </>
    )}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline define:vars={{ sitioNombre: SITIO.nombre }}>
      // Tracking de clicks: SIEMPRE a Supabase (tabla seo_clicks, insert-only) y,
      // si GA4 está activo (ga_id), también a gtag. Silencioso: nunca rompe la página.
      const SUPA_URL = 'https://pgghzmlegyxkxgivlioy.supabase.co';
      const SUPA_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBnZ2h6bWxlZ3l4a3hnaXZsaW95Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA1NDE1OTUsImV4cCI6MjA5NjExNzU5NX0.SwlVjQKdzmzQCREgjw_wF2iPxKCM6PAnioukBDOrC8M';

      function beacon(fila) {
        try {
          fetch(SUPA_URL + '/rest/v1/seo_clicks', {
            method: 'POST',
            keepalive: true,
            headers: {
              'Content-Type': 'application/json',
              apikey: SUPA_ANON,
              Authorization: 'Bearer ' + SUPA_ANON,
              Prefer: 'return=minimal',
            },
            body: JSON.stringify(fila),
          }).catch(() => {});
        } catch (e) { /* nunca romper la página por tracking */ }
      }

      document.addEventListener('click', (e) => {
        const el = e.target.closest('a, button');
        if (!el) return;
        const destino = el.href || '';
        const g = window.gtag;

        // Clicks de afiliado nombrados (data-evento en los links del modal / CTA directo).
        const evento = el.getAttribute('data-evento');
        if (evento) {
          const nombreEvento = evento === 'checkout' ? 'cta_checkout' : 'cta_pagina_ventas';
          const producto = el.getAttribute('data-producto') || '';
          const tema = el.getAttribute('data-tema') || null;
          beacon({ sitio: sitioNombre, path: location.pathname, evento: nombreEvento,
                   seccion: 'cta', etiqueta: (el.textContent || '').trim().slice(0, 60),
                   destino, producto, tema });
          if (typeof g === 'function') g('event', nombreEvento, { producto, destino });
          return;
        }

        // Cualquier otro click en un link o botón: sección + texto + destino.
        let seccion = 'contenido';
        if (el.closest('.site-header')) seccion = 'nav';
        else if (el.closest('.filtros')) seccion = 'blog-filtro';
        else if (el.closest('.site-footer')) seccion = 'footer';
        else if (el.closest('.card')) seccion = 'post-card';
        else if (el.closest('.elegir-dlg') || el.matches('.btn, .btn-acento')) seccion = 'cta';

        const etiqueta = (el.textContent || '').trim().slice(0, 60);
        beacon({ sitio: sitioNombre, path: location.pathname, evento: 'click_ui',
                 seccion, etiqueta, destino });
        if (typeof g === 'function') g('event', 'click_ui', { seccion, etiqueta, destino });
      });
    </script>
  </body>
</html>
