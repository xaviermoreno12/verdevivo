---
import { url } from '../lib/sitio.ts';

interface Props {
  post: {
    id: string;
    data: { title: string; description: string; pubDate: Date; heroImage?: string; heroAlt?: string };
  };
}
const { post } = Astro.props;
const fecha = post.data.pubDate.toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
const href = url(`/blog/${post.id}`);
---
<article class="card">
  {post.data.heroImage && (
    <a href={href}><img src={post.data.heroImage} alt={post.data.heroAlt ?? post.data.title} loading="lazy" width="400" height="225" style="border-radius:0;aspect-ratio:16/9;object-fit:cover" /></a>
  )}
  <div class="card-body">
    <h3><a href={href} style="color:inherit">{post.data.title}</a></h3>
    <p class="muted" style="font-size:.95rem">{post.data.description}</p>
    <p class="meta">{fecha}</p>
  </div>
</article>
