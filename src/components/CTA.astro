---
// Caja de CTA de afiliado. El botón abre el cartel de 2 opciones (checkout / página de ventas)
// en vez de mandar directo a pagar. rel="sponsored nofollow" lo pone ElegirDestino.
import { PRODUCTO_DESTACADO } from '../lib/sitio.ts';
import ElegirDestino from './ElegirDestino.astro';

interface Props {
  producto?: typeof PRODUCTO_DESTACADO;
  titulo?: string;
  texto?: string;
}
const { producto = PRODUCTO_DESTACADO, titulo, texto } = Astro.props;
---
<div class="cta-box">
  <h3>{titulo ?? `¿Querés probar ${producto.nombre}?`}</h3>
  <p>{texto ?? producto.descripcion_corta}</p>
  <p class="precio">{producto.precio}</p>
  <ElegirDestino producto={producto} />
</div>
